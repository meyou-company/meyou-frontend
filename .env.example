# API (Nest має глобальний префікс /api)
#
# Production (Vercel): обовʼязково задати точний базовий URL Render:
# VITE_API_URL=https://meyou-api.onrender.com/api
#
# Якщо змінна порожня, у проді використовується /api і Vercel проксує його (vercel.json) на Render.
#
# Локально без змінної: dev-режим використовує /api → proxy у vite.config.js

VITE_API_URL=
